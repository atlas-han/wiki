{
	"schemaVersion": "0.1.0",
	"name": "Article",
	"behavior": "create",
	"noteContentFormat": "**Source URL**: {{url}}\n\n{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "type",
			"value": "article",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "site",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{author|split:\\\", \\\"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "clippings/article",
			"type": "multitext"
		}
	],
	"triggers": [],
	"noteNameFormat": "{{date|date:\"YYYY-MM-DD\"}}_{{title|safe_name}}",
	"path": "01.raw/articles"
}